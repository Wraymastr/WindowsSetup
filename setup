# ============================================================
# LOGIC FUNCTIONS
# ============================================================
function Run-Debloat {
    Write-ToUI "Starting Microsoft bloat removal..." "Yellow"
    $apps=@("*MicrosoftTeams*","*MSTeams*","*Clipchamp*","*Xbox*","*Cortana*",
            "*MicrosoftNews*","*BingWeather*","*GetHelp*","*FeedbackHub*",
            "*WindowsMaps*","*YourPhone*","*MicrosoftToDo*","*MicrosoftOfficeHub*",
            "*People*","*ZuneMusic*","*ZuneVideo*","Microsoft.Messaging","Microsoft.OneConnect")
    foreach ($app in $apps) {
        Write-ToUI "Checking: $app"
        Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue | ForEach-Object {
            Write-ToUI "  Removing: $($_.Name)" "Orange"
            Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue
        }
        Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue |
            Where-Object {$_.DisplayName -like $app} | ForEach-Object {
                Write-ToUI "  Removing provisioned: $($_.DisplayName)" "Orange"
                Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue
            }
    }
    Write-ToUI "Uninstalling OneDrive..." "Yellow"
    $od="$env:SystemRoot\SysWOW64\OneDriveSetup.exe"
    if(-not(Test-Path $od)){$od="$env:SystemRoot\System32\OneDriveSetup.exe"}
    if(Test-Path $od){Start-Process $od "/uninstall" -NoNewWindow -Wait; Write-ToUI "OneDrive removed." "Lime"}
    $rp="HKCU:\Software\Microsoft\Windows\CurrentVersion\Run"
    Remove-ItemProperty -Path $rp -Name "OneDrive" -ErrorAction SilentlyContinue
    Remove-ItemProperty -Path $rp -Name "com.squirrel.Teams.Teams" -ErrorAction SilentlyContinue
    Write-ToUI "Bloat removal complete!" "Lime"
}

function Run-EssentialTweaks {
    Write-ToUI "Applying essential tweaks..." "Cyan"
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection" -Name "AllowTelemetry" -Value 0 -ErrorAction SilentlyContinue
    Set-Service -Name "DiagTrack" -StartupType Disabled -ErrorAction SilentlyContinue
    $ads="HKCU:\Software\Microsoft\Windows\CurrentVersion\ContentDeliveryManager"
    "SubscribedContent-310093Enabled","SubscribedContent-353696Enabled",
    "RotatingLockScreenOverlayEnabled","SubscribedContent-338387Enabled" | ForEach-Object {
        Set-ItemProperty -Path $ads -Name $_ -Value 0 -ErrorAction SilentlyContinue
    }
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\AdvertisingInfo" "Enabled" 0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Feeds" "ShellFeedsTaskbarViewMode" 2 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "PeopleBand" 0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" "HideSCAMeetNow" 1 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\SearchSettings" "IsDynamicSearchBoxPresent" 0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search" "BingSearchEnabled" 0 -ErrorAction SilentlyContinue
    powercfg.exe /hibernate off
    Set-ItemProperty "HKLM:\SOFTWARE\Policies\Microsoft\Edge" "StartupBoostEnabled" 0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings" "ActiveHoursStart" 8  -ErrorAction SilentlyContinue
    Set-ItemProperty "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings" "ActiveHoursEnd"   17 -ErrorAction SilentlyContinue
    Write-ToUI "Privacy and performance done."

    Write-ToUI "Showing file extensions..."
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "HideFileExt" 0 -ErrorAction SilentlyContinue

    Write-ToUI "Clearing startup programs..."
    @("HKCU:\Software\Microsoft\Windows\CurrentVersion\Run",
      "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run") | ForEach-Object {
        $p=$_
        (Get-ItemProperty -Path $p -ErrorAction SilentlyContinue).PSObject.Properties |
            Where-Object {$_.Name -notlike "PS*"} | ForEach-Object {
                Write-ToUI "  Disabling: $($_.Name)" "Orange"
                Remove-ItemProperty -Path $p -Name $_.Name -ErrorAction SilentlyContinue
            }
    }

    Write-ToUI "Restoring Win10 right-click menu..."
    $rc="HKCU:\Software\Classes\CLSID\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}\InprocServer32"
    if(-not(Test-Path $rc)){New-Item -Path $rc -Force | Out-Null}
    Set-ItemProperty -Path $rc -Name "(default)" -Value "" -ErrorAction SilentlyContinue
    Stop-Process -Name "explorer" -Force -ErrorAction SilentlyContinue
    Start-Sleep -Seconds 2; Start-Process "explorer.exe"
    Write-ToUI "All essential tweaks complete!" "Lime"
}

function Set-ChromeDefault {
    Write-ToUI "Setting Chrome as default browser..." "Cyan"
    $ce="${env:ProgramFiles}\Google\Chrome\Application\chrome.exe"
    if(-not(Test-Path $ce)){$ce="${env:ProgramFiles(x86)}\Google\Chrome\Application\chrome.exe"}
    if(Test-Path $ce){Start-Process $ce "--make-default-browser" -NoNewWindow -Wait; Write-ToUI "Chrome default set." "Lime"}
    else{Write-ToUI "Chrome not found." "Orange"}
}

function Set-VLCDefault {
    Write-ToUI "Setting VLC as default media player..." "Cyan"
    $ve="${env:ProgramFiles}\VideoLAN\VLC\vlc.exe"
    if(-not(Test-Path $ve)){$ve="${env:ProgramFiles(x86)}\VideoLAN\VLC\vlc.exe"}
    if(-not(Test-Path $ve)){Write-ToUI "VLC not found." "Orange"; return}
    ".mp4",".mkv",".avi",".mov",".wmv",".mp3",".wav",".flac",".m4a",".aac",".m4v",".ts",".mpg",".mpeg" | ForEach-Object {
        $pid2="VLC$_"; $pp="HKCU:\Software\Classes\$pid2"
        if(-not(Test-Path $pp)){New-Item -Path $pp -Force | Out-Null}
        New-Item -Path "$pp\shell\open\command" -Force | Out-Null
        Set-ItemProperty "$pp\shell\open\command" "(default)" "`"$ve`" `"%1`"" -ErrorAction SilentlyContinue
        $ep="HKCU:\Software\Classes\$_"
        if(-not(Test-Path $ep)){New-Item -Path $ep -Force | Out-Null}
        Set-ItemProperty $ep "(default)" $pid2 -ErrorAction SilentlyContinue
        $uc="HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\FileExts\$_\UserChoice"
        if(-not(Test-Path $uc)){New-Item -Path $uc -Force | Out-Null}
        Set-ItemProperty $uc "ProgId" $pid2 -ErrorAction SilentlyContinue
        Write-ToUI "  $_ -> VLC"
    }
    Write-ToUI "VLC defaults set." "Lime"
}

function Run-Installs($AppList, $DoChrome, $DoVLC) {
    if($AppList.Count -gt 0) {
        Write-ToUI "Configuring Winget..." "Cyan"
        winget settings --enable bypasscertificatepinningformicrosoftstore
        Start-Sleep -Seconds 2
        foreach($id in $AppList) {
            Write-ToUI "Installing $id..."
            winget install --id $id -e --accept-source-agreements --accept-package-agreements --silent
            Write-ToUI "  Done: $id" "Lime"
        }
    }
    if($DoChrome){Set-ChromeDefault}
    if($DoVLC)   {Set-VLCDefault}
    Write-ToUI "App installs complete!" "Lime"
}

# ============================================================
# APP PICKER — closes BEFORE running, every time
# ============================================================
function Show-AppPicker($RunAfter) {
    # Capture results in script-scope vars then close, THEN invoke callback
    $script:pickerSelected = @()
    $script:pickerChrome   = $false
    $script:pickerVLC      = $false
    $script:pickerConfirmed= $false

    $AF = New-Object Windows.Forms.Form
    $AF.Text="Select Apps to Install"; $AF.StartPosition="CenterParent"
    $AF.BackColor=$bgSubForm; $AF.ForeColor=$txtPrimary
    $AF.FormBorderStyle="FixedDialog"; $AF.MaximizeBox=$false; $AF.MinimizeBox=$false

    $script:ay = 10
    $cbs = [ordered]@{}

    function AP-Section($title) {
        $s=New-Object Windows.Forms.Label
        $s.Text=$title; $s.Location="14,$($script:ay)"; $s.Size="370,14"
        $s.ForeColor=$txtMuted; $s.BackColor=[Drawing.Color]::Transparent
        $s.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold)
        $AF.Controls.Add($s); $script:ay+=18
    }

    function AP-Check($label,$id,$on) {
        $cb=New-Object Windows.Forms.CheckBox
        $cb.Text=$label; $cb.Location="18,$($script:ay)"; $cb.Size="360,20"
        $cb.ForeColor=$txtPrimary; $cb.BackColor=[Drawing.Color]::Transparent
        $cb.Font=New-Object Drawing.Font("Segoe UI",9); $cb.Checked=$on
        $AF.Controls.Add($cb); $script:ay+=22; $cbs[$id]=$cb
    }

    # -------------------------------------------------------
    # CRITICAL — always on by default
    # -------------------------------------------------------
    AP-Section "CRITICAL  (ticked by default)"
    AP-Check "Microsoft 365 Desktop Suite" "Microsoft.Office"                $true
    AP-Check "Google Chrome"               "Google.Chrome"                   $true
    AP-Check "Mozilla Firefox"             "Mozilla.Firefox"                 $true
    AP-Check "Google Drive"                "Google.GoogleDrive"              $true
    AP-Check "VLC Media Player"            "VideoLAN.VLC"                    $true
    AP-Check "7-Zip"                       "7zip.7zip"                       $true

    $script:ay += 6
    # -------------------------------------------------------
    # OPTIONAL — off by default
    # -------------------------------------------------------
    AP-Section "OPTIONAL  (unticked by default)"
    AP-Check "LocalSend"                   "LocalSend.LocalSend"             $false
    AP-Check "CrystalDiskInfo"             "CrystalDewWorld.CrystalDiskInfo" $false
    AP-Check "Angry IP Scanner"            "Angryziber.AngryIPScanner"       $false
    AP-Check "Everything  (fast search)"   "voidtools.Everything"            $false
    AP-Check "HP Support Assistant"        "HP.HPSupportAssistant"           $false
    AP-Check "Malwarebytes"                "Malwarebytes.Malwarebytes"       $false
    AP-Check "Winaero Tweaker"             "WinAero.WinaeroTweaker"          $false
    # ShutUp10 has no winget ID — download from https://www.oo-software.com/shutup10

    $script:ay += 8
    AP-Section "SET AS DEFAULT"

    $cbCD=New-Object Windows.Forms.CheckBox; $cbCD.Text="Set Chrome as default browser"
    $cbCD.Location="18,$($script:ay)"; $cbCD.Size="360,20"
    $cbCD.ForeColor=$txtPrimary; $cbCD.BackColor=[Drawing.Color]::Transparent
    $cbCD.Font=New-Object Drawing.Font("Segoe UI",9); $cbCD.Checked=$true
    $AF.Controls.Add($cbCD); $script:ay+=22

    $cbVD=New-Object Windows.Forms.CheckBox; $cbVD.Text="Set VLC as default media player"
    $cbVD.Location="18,$($script:ay)"; $cbVD.Size="360,20"
    $cbVD.ForeColor=$txtPrimary; $cbVD.BackColor=[Drawing.Color]::Transparent
    $cbVD.Font=New-Object Drawing.Font("Segoe UI",9); $cbVD.Checked=$true
    $AF.Controls.Add($cbVD); $script:ay+=30

    # Select All / None row
    $bSA=New-Object Windows.Forms.Button; $bSA.Text="Select All"
    $bSA.Location="14,$($script:ay)"; $bSA.Size="176,28"
    $bSA.FlatStyle="Flat"; $bSA.ForeColor=$txtPrimary; $bSA.BackColor=$bgPanel
    $bSA.FlatAppearance.BorderColor=$border; $bSA.FlatAppearance.BorderSize=1
    $bSA.Add_Click({foreach($c in $cbs.Values){$c.Checked=$true};$cbCD.Checked=$true;$cbVD.Checked=$true})
    $AF.Controls.Add($bSA)

    $bSN=New-Object Windows.Forms.Button; $bSN.Text="Select None"
    $bSN.Location="198,$($script:ay)"; $bSN.Size="176,28"
    $bSN.FlatStyle="Flat"; $bSN.ForeColor=$txtPrimary; $bSN.BackColor=$bgPanel
    $bSN.FlatAppearance.BorderColor=$border; $bSN.FlatAppearance.BorderSize=1
    $bSN.Add_Click({foreach($c in $cbs.Values){$c.Checked=$false};$cbCD.Checked=$false;$cbVD.Checked=$false})
    $AF.Controls.Add($bSN); $script:ay+=36

    # GO button
    $bGo=New-Object Windows.Forms.Button; $bGo.Text="  INSTALL SELECTED"
    $bGo.Location="14,$($script:ay)"; $bGo.Size="360,38"
    $bGo.FlatStyle="Flat"; $bGo.ForeColor=$btnTeal[1]; $bGo.BackColor=$btnTeal[0]
    $bGo.Font=New-Object Drawing.Font("Segoe UI",10,[Drawing.FontStyle]::Bold)
    $bGo.FlatAppearance.BorderColor=$border; $bGo.FlatAppearance.BorderSize=1
    $bGo.TextAlign="MiddleLeft"; $bGo.Padding=New-Object Windows.Forms.Padding(10,0,0,0)
    $bGo.Add_Click({
        $sel=@(); foreach($id in $cbs.Keys){if($cbs[$id].Checked){$sel+=$id}}
        if($sel.Count -eq 0 -and -not $cbCD.Checked -and -not $cbVD.Checked){
            [Windows.Forms.MessageBox]::Show("Nothing selected!","Nothing to do"); return}
        # Store results in script scope then close — this is the fix for the hanging window
        $script:pickerSelected  = $sel
        $script:pickerChrome    = $cbCD.Checked
        $script:pickerVLC       = $cbVD.Checked
        $script:pickerConfirmed = $true
        $AF.Close()
    })
    $AF.Controls.Add($bGo); $script:ay+=50

    $AF.Size="398,$($script:ay)"
    $AF.ShowDialog() | Out-Null

    # Now the window is fully gone — THEN run the callback
    if($script:pickerConfirmed) {
        & $RunAfter $script:pickerSelected $script:pickerChrome $script:pickerVLC
    }
}

# ============================================================
# BUTTON HANDLERS
# ============================================================
$b1.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b1.Enabled=$false; $b1.Text="  Working..."
    Run-Debloat
    $b1.Text="  Remove MS Bloat"; $b1.Enabled=$true
})

$b2.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b2.Enabled=$false; $b2.Text="  Working..."
    Write-ToUI "Starting HP bloat removal..." "Yellow"
    @("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings",
      "HP.HPConnectionOptimizer","HP.HPSmart") | ForEach-Object {
        Write-ToUI "  Uninstalling $_..."
        winget uninstall --id $_ -e --accept-source-agreements -h --force 2>&1 | Out-Null
    }
    Get-CimInstance Win32_Product -ErrorAction SilentlyContinue |
        Where-Object {$_.Name -like "*HP Wolf*" -or $_.Name -like "*HP Sure Sense*"} |
        ForEach-Object {
            Write-ToUI "  Force removing: $($_.Name)" "Orange"
            Invoke-CimMethod -InputObject $_ -MethodName "Uninstall" | Out-Null
        }
    Write-ToUI "HP cleanup complete!" "Lime"
    $b2.Text="  HP Cleanup"; $b2.Enabled=$true
})

$b3.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b3.Enabled=$false; $b3.Text="  Working..."
    Run-EssentialTweaks
    $b3.Text="  Essential Tweaks"; $b3.Enabled=$true
})

$b4.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b4.Enabled=$false; $b4.Text="  Working..."
    Show-AppPicker {
        param($sel,$chrome,$vlc)
        Run-Installs $sel $chrome $vlc
        $b4.Text="  Install Apps"; $b4.Enabled=$true
    }
})

$bAll.Add_Click({
    if([Windows.Forms.MessageBox]::Show(
        "Full setup will run:`n`n  Remove MS Bloat`n  Essential Tweaks`n  Install selected apps`n`nChoose apps on the next screen.",
        "Run All","YesNo") -ne "Yes"){return}
    [System.Media.SystemSounds]::Asterisk.Play()

    Show-AppPicker {
        param($sel,$chrome,$vlc)
        foreach($btn in @($bAll,$b1,$b2,$b3,$b4)){$btn.Enabled=$false}
        $bAll.Text="  Running..."
        Write-ToUI "=== FULL SETUP STARTED ===" "Yellow"
        Run-Debloat
        Run-EssentialTweaks
        Run-Installs $sel $chrome $vlc
        Write-ToUI "=== COMPLETE — PLEASE RESTART ===" "Yellow"
        [System.Media.SystemSounds]::Exclamation.Play()
        [Windows.Forms.MessageBox]::Show("All done!`n`nRestart recommended.","Complete!")
        Refresh-SystemInfo
        $bAll.Text="  RUN ALL — Full Teacher Setup"
        foreach($btn in @($bAll,$b1,$b2,$b3,$b4)){$btn.Enabled=$true}
    }
})

$Form.ShowDialog()
