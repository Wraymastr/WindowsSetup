# --- Hover effect helper ---
function Make-Clickable($lbl, $baseColor) {
    $lbl.Cursor = [System.Windows.Forms.Cursors]::Hand
    $lbl.Add_MouseEnter({
        $lbl.ForeColor = [System.Drawing.Color]::White
        $lbl.Font = New-Object Drawing.Font("Consolas", 8, [Drawing.FontStyle]::Underline)
    })
    $lbl.Add_MouseLeave({
        $lbl.ForeColor = $baseColor
        $lbl.Font = New-Object Drawing.Font("Consolas", 8)
    })
}

Make-Clickable $lblComputer ([System.Drawing.Color]::Lime)
Make-Clickable $lblUser     ([System.Drawing.Color]::Lime)
Make-Clickable $lblWindows  ([System.Drawing.Color]::Lime)
Make-Clickable $lblDomain   ([System.Drawing.Color]::Yellow)
Make-Clickable $lblUptime   ([System.Drawing.Color]::Lime)

# ============================================================
# REFRESH SYSTEM INFO
# ============================================================
function Refresh-SystemInfo {
    $cs = Get-CimInstance Win32_ComputerSystem
    $os = Get-CimInstance Win32_OperatingSystem
    $lblComputer.Text = $cs.Name
    $lblUser.Text     = $env:USERNAME
    $lblWindows.Text  = "$($os.Caption) (Build $($os.BuildNumber))"
    if ($cs.PartOfDomain) {
        $lblDomain.Text      = "DOMAIN: $($cs.Domain)"
        $lblDomain.ForeColor = [System.Drawing.Color]::Cyan
    } else {
        $lblDomain.Text      = "WORKGROUP: $($cs.Workgroup)"
        $lblDomain.ForeColor = [System.Drawing.Color]::Yellow
    }
    $uptime = (Get-Date) - $os.LastBootUpTime
    $lblUptime.Text = "$([int]$uptime.TotalHours)h $($uptime.Minutes)m since last boot"
}

Refresh-SystemInfo

$RefreshBtn = New-Object Windows.Forms.Button
$RefreshBtn.Text = "↻ Refresh"
$RefreshBtn.Location = "340,88"
$RefreshBtn.Size = "68,18"
$RefreshBtn.FlatStyle = "Flat"
$RefreshBtn.Font = New-Object Drawing.Font("Segoe UI", 7)
$RefreshBtn.ForeColor = "White"
$RefreshBtn.BackColor = [Drawing.Color]::FromArgb(50,50,50)
$RefreshBtn.Add_Click({ Refresh-SystemInfo })
$InfoPanel.Controls.Add($RefreshBtn)

# ============================================================
# CLICK: COMPUTER NAME -> RENAME
# ============================================================
$lblComputer.Add_Click({
    $RenameForm = New-Object Windows.Forms.Form
    $RenameForm.Text = "Rename This Computer"
    $RenameForm.Size = "360,185"
    $RenameForm.StartPosition = "CenterParent"
    $RenameForm.BackColor = [Drawing.Color]::FromArgb(30, 30, 30)
    $RenameForm.FormBorderStyle = "FixedDialog"
    $RenameForm.MaximizeBox = $false

    $l1 = New-Object Windows.Forms.Label
    $l1.Text = "Current name:  $($lblComputer.Text)"
    $l1.Location = "15,15"; $l1.Size = "310,18"
    $l1.ForeColor = "Gray"; $l1.Font = New-Object Drawing.Font("Consolas", 8)

    $l2 = New-Object Windows.Forms.Label
    $l2.Text = "New computer name (max 15 chars):"
    $l2.Location = "15,38"; $l2.Size = "310,18"
    $l2.ForeColor = "White"; $l2.Font = New-Object Drawing.Font("Segoe UI", 9)

    $txtName = New-Object Windows.Forms.TextBox
    $txtName.Location = "15,58"; $txtName.Size = "310,25"
    $txtName.Text = $lblComputer.Text
    $txtName.SelectAll()

    $btnRename = New-Object Windows.Forms.Button
    $btnRename.Text = "Rename (restart required)"
    $btnRename.Location = "15,95"; $btnRename.Size = "205,35"
    $btnRename.FlatStyle = "Flat"; $btnRename.ForeColor = "White"
    $btnRename.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#5bc0de")
    $btnRename.Font = New-Object Drawing.Font("Segoe UI", 9, [Drawing.FontStyle]::Bold)
    $btnRename.Add_Click({
        $newName = $txtName.Text.Trim()
        if ([string]::IsNullOrWhiteSpace($newName) -or $newName -eq $lblComputer.Text) {
            [Windows.Forms.MessageBox]::Show("Please enter a new name.", "No Change"); return
        }
        if ($newName.Length -gt 15) {
            [Windows.Forms.MessageBox]::Show("Max 15 characters!", "Too Long"); return
        }
        try {
            Rename-Computer -NewName $newName -Force -ErrorAction Stop
            Write-ToUI "Computer renamed to '$newName' — restart to apply." "Cyan"
            [Windows.Forms.MessageBox]::Show("Renamed to '$newName'.`nRestart when ready.", "Done")
            $RenameForm.Close()
            Refresh-SystemInfo
        } catch {
            [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)", "Error")
        }
    })

    $btnCancel = New-Object Windows.Forms.Button
    $btnCancel.Text = "Cancel"
    $btnCancel.Location = "228,95"; $btnCancel.Size = "97,35"
    $btnCancel.FlatStyle = "Flat"; $btnCancel.ForeColor = "White"
    $btnCancel.BackColor = [Drawing.Color]::FromArgb(60,60,60)
    $btnCancel.Add_Click({ $RenameForm.Close() })

    $RenameForm.Controls.AddRange(@($l1, $l2, $txtName, $btnRename, $btnCancel))
    $RenameForm.ShowDialog()
})

# ============================================================
# CLICK: USERNAME -> PASSWORD CHANGE
# ============================================================
$lblUser.Add_Click({
    $PassForm = New-Object Windows.Forms.Form
    $PassForm.Text = "Change User Password"
    $PassForm.Size = "360,235"
    $PassForm.StartPosition = "CenterParent"
    $PassForm.BackColor = [Drawing.Color]::FromArgb(30, 30, 30)
    $PassForm.FormBorderStyle = "FixedDialog"
    $PassForm.MaximizeBox = $false

    $l1 = New-Object Windows.Forms.Label
    $l1.Text = "Changing password for:  $($env:USERNAME)"
    $l1.Location = "15,15"; $l1.Size = "310,18"
    $l1.ForeColor = "Gray"; $l1.Font = New-Object Drawing.Font("Consolas", 8)

    $l2 = New-Object Windows.Forms.Label
    $l2.Text = "New Password:"; $l2.Location = "15,40"; $l2.Size = "310,18"
    $l2.ForeColor = "White"; $l2.Font = New-Object Drawing.Font("Segoe UI", 9)

    $txtP1 = New-Object Windows.Forms.TextBox
    $txtP1.Location = "15,60"; $txtP1.Size = "310,25"
    $txtP1.UseSystemPasswordChar = $true

    $l3 = New-Object Windows.Forms.Label
    $l3.Text = "Confirm Password:"; $l3.Location = "15,95"; $l3.Size = "310,18"
    $l3.ForeColor = "White"; $l3.Font = New-Object Drawing.Font("Segoe UI", 9)

    $txtP2 = New-Object Windows.Forms.TextBox
    $txtP2.Location = "15,115"; $txtP2.Size = "310,25"
    $txtP2.UseSystemPasswordChar = $true

    $btnChange = New-Object Windows.Forms.Button
    $btnChange.Text = "Change Password"
    $btnChange.Location = "15,155"; $btnChange.Size = "200,35"
    $btnChange.FlatStyle = "Flat"; $btnChange.ForeColor = "White"
    $btnChange.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#f0ad4e")
    $btnChange.Font = New-Object Drawing.Font("Segoe UI", 9, [Drawing.FontStyle]::Bold)
    $btnChange.Add_Click({
        if ($txtP1.Text -ne $txtP2.Text) {
            [System.Media.SystemSounds]::Hand.Play()
            [Windows.Forms.MessageBox]::Show("Passwords do not match!", "Error"); return
        }
        if ($txtP1.Text.Length -lt 1) {
            [Windows.Forms.MessageBox]::Show("Password cannot be empty.", "Error"); return
        }
        try {
            $user = [adsi]"WinNT://./$($env:USERNAME),user"
            $user.SetPassword($txtP1.Text)
            $user.SetInfo()
            Write-ToUI "Password changed for $($env:USERNAME)." "Lime"
            [Windows.Forms.MessageBox]::Show("Password changed successfully!", "Done")
            $PassForm.Close()
        } catch {
            [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)", "Error")
        }
    })

    $btnCancel = New-Object Windows.Forms.Button
    $btnCancel.Text = "Cancel"
    $btnCancel.Location = "223,155"; $btnCancel.Size = "102,35"
    $btnCancel.FlatStyle = "Flat"; $btnCancel.ForeColor = "White"
    $btnCancel.BackColor = [Drawing.Color]::FromArgb(60,60,60)
    $btnCancel.Add_Click({ $PassForm.Close() })

    $PassForm.Controls.AddRange(@($l1,$l2,$txtP1,$l3,$txtP2,$btnChange,$btnCancel))
    $PassForm.ShowDialog()
})

# ============================================================
# CLICK: WINDOWS VERSION -> PRODUCT KEY INPUT
# ============================================================
$lblWindows.Add_Click({
    $KeyForm = New-Object Windows.Forms.Form
    $KeyForm.Text = "Enter Product Key"
    $KeyForm.Size = "380,185"
    $KeyForm.StartPosition = "CenterParent"
    $KeyForm.BackColor = [Drawing.Color]::FromArgb(30, 30, 30)
    $KeyForm.FormBorderStyle = "FixedDialog"
    $KeyForm.MaximizeBox = $false

    $l1 = New-Object Windows.Forms.Label
    $l1.Text = "Windows Product Key:"
    $l1.Location = "15,15"; $l1.Size = "330,18"
    $l1.ForeColor = "White"; $l1.Font = New-Object Drawing.Font("Segoe UI", 9)

    $l2 = New-Object Windows.Forms.Label
    $l2.Text = "Format: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"
    $l2.Location = "15,35"; $l2.Size = "330,16"
    $l2.ForeColor = "Gray"; $l2.Font = New-Object Drawing.Font("Consolas", 7)

    $txtKey = New-Object Windows.Forms.TextBox
    $txtKey.Location = "15,58"; $txtKey.Size = "330,25"
    $txtKey.Font = New-Object Drawing.Font("Consolas", 10)
    $txtKey.CharacterCasing = "Upper"

    # ===========================================================
    # DEFAULT PRODUCT KEY — CHANGE THIS LINE TO UPDATE THE KEY
    # ===========================================================
    $txtKey.Text = "H3T4N-27DJJ-D2PMR-HY8BG-MKMM3"
    # ===========================================================

    $txtKey.SelectAll()

    $btnActivate = New-Object Windows.Forms.Button
    $btnActivate.Text = "Activate Windows"
    $btnActivate.Location = "15,95"; $btnActivate.Size = "205,35"
    $btnActivate.FlatStyle = "Flat"; $btnActivate.ForeColor = "White"
    $btnActivate.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#5cb85c")
    $btnActivate.Font = New-Object Drawing.Font("Segoe UI", 9, [Drawing.FontStyle]::Bold)
    $btnActivate.Add_Click({
        $key = $txtKey.Text.Trim()
        # Basic format check: 5 groups of 5 chars separated by dashes
        if ($key -notmatch "^[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}$") {
            [Windows.Forms.MessageBox]::Show("Key format looks wrong.`nExpected: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX", "Invalid Key")
            return
        }
        try {
            Write-ToUI "Installing product key..." "Cyan"
            $result = & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ipk $key 2>&1
            Write-ToUI "Activating with Microsoft..." "Cyan"
            & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ato 2>&1 | Out-Null
            Write-ToUI "Activation complete." "Lime"
            [Windows.Forms.MessageBox]::Show("Key applied and activation attempted.`nCheck Settings > Activation for status.", "Done")
            $KeyForm.Close()
        } catch {
            [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)", "Error")
        }
    })

    $btnCancel = New-Object Windows.Forms.Button
    $btnCancel.Text = "Cancel"
    $btnCancel.Location = "228,95"; $btnCancel.Size = "117,35"
    $btnCancel.FlatStyle = "Flat"; $btnCancel.ForeColor = "White"
    $btnCancel.BackColor = [Drawing.Color]::FromArgb(60,60,60)
    $btnCancel.Add_Click({ $KeyForm.Close() })

    $KeyForm.Controls.AddRange(@($l1,$l2,$txtKey,$btnActivate,$btnCancel))
    $KeyForm.ShowDialog()
})

# ============================================================
# CLICK: DOMAIN -> DOMAIN TOOLS
# ============================================================
$lblDomain.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    Write-ToUI "Opening Domain Tools..." "Cyan"

    $DomainForm = New-Object Windows.Forms.Form
    $DomainForm.Text = "Domain Manager"
    $DomainForm.Size = "360,230"
    $DomainForm.StartPosition = "CenterParent"
    $DomainForm.BackColor = [Drawing.Color]::FromArgb(30, 30, 30)
    $DomainForm.FormBorderStyle = "FixedDialog"
    $DomainForm.MaximizeBox = $false

    $lbl = New-Object Windows.Forms.Label
    $lbl.Text = "Domain Name:"; $lbl.Location = "20,20"; $lbl.Size = "300,20"
    $lbl.ForeColor = "White"

    $txt = New-Object Windows.Forms.TextBox
    $txt.Location = "20,45"; $txt.Size = "300,25"

    $joinBtn = New-Object Windows.Forms.Button
    $joinBtn.Text = "Join Domain (will reboot)"
    $joinBtn.Location = "20,85"; $joinBtn.Size = "300,38"
    $joinBtn.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#5cb85c")
    $joinBtn.ForeColor = "White"; $joinBtn.FlatStyle = "Flat"
    $joinBtn.Add_Click({
        if ([string]::IsNullOrWhiteSpace($txt.Text)) {
            [System.Media.SystemSounds]::Hand.Play()
            [Windows.Forms.MessageBox]::Show("Enter a domain name first!", "Error"); return
        }
        $confirm = [Windows.Forms.MessageBox]::Show("Join '$($txt.Text)' and reboot?", "Confirm", "YesNo")
        if ($confirm -eq "Yes") {
            try { Add-Computer -DomainName $txt.Text -Restart -ErrorAction Stop }
            catch { [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)") }
        }
    })

    $leaveBtn = New-Object Windows.Forms.Button
    $leaveBtn.Text = "Leave Domain (back to WORKGROUP)"
    $leaveBtn.Location = "20,133"; $leaveBtn.Size = "300,38"
    $leaveBtn.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#d9534f")
    $leaveBtn.ForeColor = "White"; $leaveBtn.FlatStyle = "Flat"
    $leaveBtn.Add_Click({
        $confirm = [Windows.Forms.MessageBox]::Show("Leave domain and reboot?", "Confirm", "YesNo")
        if ($confirm -eq "Yes") { Remove-Computer -WorkgroupName "WORKGROUP" -Force -Restart }
    })

    $DomainForm.Controls.AddRange(@($lbl, $txt, $joinBtn, $leaveBtn))
    $DomainForm.ShowDialog()
    Refresh-SystemInfo
})

