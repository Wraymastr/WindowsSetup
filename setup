function New-InfoLabel($Text, $X, $Y, $W, $Color = "Gray") {
    $lbl = New-Object Windows.Forms.Label
    $lbl.Text = $Text
    $lbl.Location = "$X,$Y"
    $lbl.Size = "$W,18"
    $lbl.ForeColor = $Color
    $lbl.Font = New-Object Drawing.Font("Consolas", 8)
    $InfoPanel.Controls.Add($lbl)
    return $lbl
}

