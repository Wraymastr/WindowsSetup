# ============================================================
# OUTPUT CONSOLE
# ============================================================
$ConsoleOutput = New-Object Windows.Forms.RichTextBox
$ConsoleOutput.Location = "10,390"
$ConsoleOutput.Size = "415,280"
$ConsoleOutput.BackColor = "Black"
$ConsoleOutput.ForeColor = "Lime"
$ConsoleOutput.ReadOnly = $true
$ConsoleOutput.Font = New-Object Drawing.Font("Consolas", 8)
$Form.Controls.Add($ConsoleOutput)

function Write-ToUI($Message, $Color = "Lime") {
    $ConsoleOutput.SelectionStart = $ConsoleOutput.TextLength
    $ConsoleOutput.SelectionLength = 0
    $ConsoleOutput.SelectionColor = [System.Drawing.Color]::$Color
    $ConsoleOutput.AppendText("[$((Get-Date).ToString('HH:mm:ss'))] $Message`r`n")
    $ConsoleOutput.ScrollToCaret()
    $Form.Refresh()
}

# ============================================================
# APP PICKER - shared function used by both Install button
# and Run All so the subform always closes before work starts
# ============================================================
function Show-AppPicker($RunAfter) {
    $AppForm = New-Object Windows.Forms.Form
    $AppForm.Text = "Select Apps to Install"
    $AppForm.Size = "360,100"   # will be resized dynamically below
    $AppForm.StartPosition = "CenterParent"
    $AppForm.BackColor = [Drawing.Color]::FromArgb(30, 30, 30)
    $AppForm.FormBorderStyle = "FixedDialog"
    $AppForm.MaximizeBox = $false

    $appHeader = New-Object Windows.Forms.Label
    $appHeader.Text = "Choose apps to install:"
    $appHeader.Location = "15,12"; $appHeader.Size = "300,20"
    $appHeader.ForeColor = "White"
    $appHeader.Font = New-Object Drawing.Font("Segoe UI", 10, [Drawing.FontStyle]::Bold)
    $AppForm.Controls.Add($appHeader)

    # -------------------------------------------------------
    # APP LIST — add or remove entries here as needed
    # Format: "Display Name" = "Winget.ID"
    # -------------------------------------------------------
    $appDefinitions = [ordered]@{
        "Google Chrome"        = "Google.Chrome"
        "Google Drive"         = "Google.GoogleDrive"
        "Mozilla Firefox"      = "Mozilla.Firefox"
        "VLC Media Player"     = "VideoLAN.VLC"
        "Adobe Acrobat Reader" = "Adobe.Acrobat.Reader.64-bit"
        "Zoom"                 = "Zoom.Zoom"
    }
    # -------------------------------------------------------

    $checkboxes = @{}
    $yPos = 40
    foreach ($appName in $appDefinitions.Keys) {
        $cb = New-Object Windows.Forms.CheckBox
        $cb.Text = $appName; $cb.Location = "20,$yPos"; $cb.Size = "300,24"
        $cb.ForeColor = "White"; $cb.Font = New-Object Drawing.Font("Segoe UI", 9)
        $cb.Checked = $true
        $AppForm.Controls.Add($cb)
        $checkboxes[$appName] = $cb
        $yPos += 28
    }

    # Divider
    $div = New-Object Windows.Forms.Label
    $div.Text = "─────────── Set as Default ───────────"
    $div.Location = "15,$yPos"; $div.Size = "310,18"
    $div.ForeColor = "Gray"; $div.Font = New-Object Drawing.Font("Consolas", 8)
    $AppForm.Controls.Add($div)
    $yPos += 24

    $cbChromeDef = New-Object Windows.Forms.CheckBox
    $cbChromeDef.Text = "Set Chrome as default browser"
    $cbChromeDef.Location = "20,$yPos"; $cbChromeDef.Size = "300,24"
    $cbChromeDef.ForeColor = "White"; $cbChromeDef.Font = New-Object Drawing.Font("Segoe UI", 9)
    $cbChromeDef.Checked = $true
    $AppForm.Controls.Add($cbChromeDef)
    $yPos += 28

    $cbVLCDef = New-Object Windows.Forms.CheckBox
    $cbVLCDef.Text = "Set VLC as default media player"
    $cbVLCDef.Location = "20,$yPos"; $cbVLCDef.Size = "300,24"
    $cbVLCDef.ForeColor = "White"; $cbVLCDef.Font = New-Object Drawing.Font("Segoe UI", 9)
    $cbVLCDef.Checked = $true
    $AppForm.Controls.Add($cbVLCDef)
    $yPos += 36

    # Select All / None
    $btnSelAll = New-Object Windows.Forms.Button
    $btnSelAll.Text = "Select All"; $btnSelAll.Location = "20,$yPos"; $btnSelAll.Size = "140,28"
    $btnSelAll.FlatStyle = "Flat"; $btnSelAll.ForeColor = "White"
    $btnSelAll.BackColor = [Drawing.Color]::FromArgb(60,60,60)
    $btnSelAll.Add_Click({
        foreach ($cb in $checkboxes.Values) { $cb.Checked = $true }
        $cbChromeDef.Checked = $true; $cbVLCDef.Checked = $true
    })
    $AppForm.Controls.Add($btnSelAll)

    $btnSelNone = New-Object Windows.Forms.Button
    $btnSelNone.Text = "Select None"; $btnSelNone.Location = "170,$yPos"; $btnSelNone.Size = "140,28"
    $btnSelNone.FlatStyle = "Flat"; $btnSelNone.ForeColor = "White"
    $btnSelNone.BackColor = [Drawing.Color]::FromArgb(60,60,60)
    $btnSelNone.Add_Click({
        foreach ($cb in $checkboxes.Values) { $cb.Checked = $false }
        $cbChromeDef.Checked = $false; $cbVLCDef.Checked = $false
    })
    $AppForm.Controls.Add($btnSelNone)
    $yPos += 38

    # GO button — closes form FIRST, then runs installs
    $btnGo = New-Object Windows.Forms.Button
    $btnGo.Text = "⬇ INSTALL SELECTED"
    $btnGo.Location = "20,$yPos"; $btnGo.Size = "295,40"
    $btnGo.FlatStyle = "Flat"; $btnGo.ForeColor = "White"
    $btnGo.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#5cb85c")
    $btnGo.Font = New-Object Drawing.Font("Segoe UI", 10, [Drawing.FontStyle]::Bold)
    $btnGo.Add_Click({
        $selected = @()
        foreach ($appName in $checkboxes.Keys) {
            if ($checkboxes[$appName].Checked) { $selected += $appDefinitions[$appName] }
        }
        $doChrome = $cbChromeDef.Checked
        $doVLC    = $cbVLCDef.Checked

        if ($selected.Count -eq 0 -and -not $doChrome -and -not $doVLC) {
            [Windows.Forms.MessageBox]::Show("Nothing selected!", "Nothing to do"); return
        }

        # CLOSE THE FORM BEFORE RUNNING — fixes the hanging prompt issue
        $AppForm.DialogResult = [Windows.Forms.DialogResult]::OK
        $AppForm.Close()

        # Hand off to the caller's script block with what was selected
        & $RunAfter $selected $doChrome $doVLC
    })
    $AppForm.Controls.Add($btnGo)

    $AppForm.Size = "360,$($yPos + 100)"
    $AppForm.ShowDialog() | Out-Null
}

# ============================================================
# SHARED LOGIC FUNCTIONS
# ============================================================
function Run-Debloat {
    Write-ToUI "Starting Microsoft bloat removal..." "Yellow"
    $bloatApps = @(
        "*MicrosoftTeams*","*MSTeams*","*Clipchamp*","*Xbox*","*Cortana*",
        "*MicrosoftNews*","*BingWeather*","*GetHelp*","*FeedbackHub*",
        "*WindowsMaps*","*YourPhone*","*MicrosoftToDo*","*MicrosoftOfficeHub*",
        "*People*","*ZuneMusic*","*ZuneVideo*","Microsoft.Messaging","Microsoft.OneConnect"
    )
    foreach ($app in $bloatApps) {
        Write-ToUI "Checking: $app"
        $packages = Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue
        foreach ($pkg in $packages) {
            Write-ToUI "  Removing: $($pkg.Name)" "Orange"
            Remove-AppxPackage -Package $pkg.PackageFullName -AllUsers -ErrorAction SilentlyContinue
        }
        Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue |
            Where-Object { $_.DisplayName -like $app } |
            ForEach-Object {
                Write-ToUI "  Removing provisioned: $($_.DisplayName)" "Orange"
                Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue
            }
    }
    Write-ToUI "Uninstalling OneDrive..." "Yellow"
    $odSetup = "$env:SystemRoot\SysWOW64\OneDriveSetup.exe"
    if (-not (Test-Path $odSetup)) { $odSetup = "$env:SystemRoot\System32\OneDriveSetup.exe" }
    if (Test-Path $odSetup) {
        Start-Process $odSetup "/uninstall" -NoNewWindow -Wait
        Write-ToUI "OneDrive removed." "Lime"
    }
    $RunPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run"
    Remove-ItemProperty -Path $RunPath -Name "OneDrive" -ErrorAction SilentlyContinue
    Remove-ItemProperty -Path $RunPath -Name "com.squirrel.Teams.Teams" -ErrorAction SilentlyContinue
    Write-ToUI "Bloat removal complete!" "Lime"
}

function Run-Privacy {
    Write-ToUI "Applying privacy and telemetry tweaks..." "Cyan"
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection" -Name "AllowTelemetry" -Value 0 -ErrorAction SilentlyContinue
    Set-Service -Name "DiagTrack" -StartupType Disabled -ErrorAction SilentlyContinue
    Write-ToUI "Telemetry disabled."
    $AdsPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\ContentDeliveryManager"
    Set-ItemProperty -Path $AdsPath -Name "SubscribedContent-310093Enabled"  -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path $AdsPath -Name "SubscribedContent-353696Enabled"  -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path $AdsPath -Name "RotatingLockScreenOverlayEnabled" -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path $AdsPath -Name "SubscribedContent-338387Enabled"  -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\AdvertisingInfo" -Name "Enabled" -Value 0 -ErrorAction SilentlyContinue
    Write-ToUI "Ads and tailored experiences disabled."
    Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Feeds" -Name "ShellFeedsTaskbarViewMode" -Value 2 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "PeopleBand" -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" -Name "HideSCAMeetNow" -Value 1 -ErrorAction SilentlyContinue
    Write-ToUI "Taskbar cleaned up."
    Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\SearchSettings" -Name "IsDynamicSearchBoxPresent" -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search" -Name "BingSearchEnabled" -Value 0 -ErrorAction SilentlyContinue
    Write-ToUI "Search bar decluttered."
    powercfg.exe /hibernate off
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Edge" -Name "StartupBoostEnabled" -Value 0 -ErrorAction SilentlyContinue
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings" -Name "ActiveHoursStart" -Value 8  -ErrorAction SilentlyContinue
    Set-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings" -Name "ActiveHoursEnd"   -Value 17 -ErrorAction SilentlyContinue
    Write-ToUI "Performance tweaks applied. Active hours set 8AM-5PM." "Lime"
}

function Set-ChromeDefault {
    Write-ToUI "Setting Chrome as default browser..." "Cyan"
    $chromeExe = "${env:ProgramFiles}\Google\Chrome\Application\chrome.exe"
    if (-not (Test-Path $chromeExe)) { $chromeExe = "${env:ProgramFiles(x86)}\Google\Chrome\Application\chrome.exe" }
    if (Test-Path $chromeExe) {
        Start-Process $chromeExe "--make-default-browser" -NoNewWindow -Wait
        Write-ToUI "Chrome default browser request sent." "Lime"
    } else {
        Write-ToUI "Chrome not found — install it first." "Orange"
    }
}

function Set-VLCDefault {
    Write-ToUI "Setting VLC as default for video/audio types..." "Cyan"
    $vlcExe = "${env:ProgramFiles}\VideoLAN\VLC\vlc.exe"
    if (-not (Test-Path $vlcExe)) { $vlcExe = "${env:ProgramFiles(x86)}\VideoLAN\VLC\vlc.exe" }
    if (-not (Test-Path $vlcExe)) { Write-ToUI "VLC not found — install it first." "Orange"; return }

    $extensions = @(".mp4",".mkv",".avi",".mov",".wmv",".mp3",".wav",".flac",".m4a",".aac",".m4v",".ts",".mpg",".mpeg")
    foreach ($ext in $extensions) {
        $progId  = "VLC$ext"
        $progPath = "HKCU:\Software\Classes\$progId"
        if (-not (Test-Path $progPath)) { New-Item -Path $progPath -Force | Out-Null }
        New-Item -Path "$progPath\shell\open\command" -Force | Out-Null
        Set-ItemProperty -Path "$progPath\shell\open\command" -Name "(default)" -Value "`"$vlcExe`" `"%1`"" -ErrorAction SilentlyContinue
        $extPath = "HKCU:\Software\Classes\$ext"
        if (-not (Test-Path $extPath)) { New-Item -Path $extPath -Force | Out-Null }
        Set-ItemProperty -Path $extPath -Name "(default)" -Value $progId -ErrorAction SilentlyContinue
        $ucPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\FileExts\$ext\UserChoice"
        if (-not (Test-Path $ucPath)) { New-Item -Path $ucPath -Force | Out-Null }
        Set-ItemProperty -Path $ucPath -Name "ProgId" -Value $progId -ErrorAction SilentlyContinue
        Write-ToUI "  $ext -> VLC"
    }
    Write-ToUI "VLC defaults set." "Lime"
}

function Run-Installs($AppList, $DoChrome, $DoVLC) {
    if ($AppList.Count -gt 0) {
        Write-ToUI "Configuring Winget..." "Cyan"
        winget settings --enable bypasscertificatepinningformicrosoftstore
        Start-Sleep -Seconds 2
        foreach ($id in $AppList) {
            Write-ToUI "Installing $id..."
            winget install --id $id -e --accept-source-agreements --accept-package-agreements --silent
            Write-ToUI "  Done: $id" "Lime"
        }
    }
    if ($DoChrome) { Set-ChromeDefault }
    if ($DoVLC)    { Set-VLCDefault }
    Write-ToUI "App section complete!" "Lime"
}

# ============================================================
# BUTTON HELPER
# ============================================================
function New-ActionButton($Text, $Top, $HexColor) {
    $Btn = New-Object Windows.Forms.Button
    $Btn.Text = $Text
    $Btn.Location = "10,$Top"
    $Btn.Size = "415,42"
    $Btn.FlatStyle = "Flat"
    $Btn.ForeColor = "White"
    $Btn.BackColor = [System.Drawing.ColorTranslator]::FromHtml($HexColor)
    $Btn.Font = New-Object Drawing.Font("Segoe UI", 10, [Drawing.FontStyle]::Bold)
    $Form.Controls.Add($Btn)
    return $Btn
}

