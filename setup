$bg          = [Drawing.Color]::FromArgb(30,  30,  36)   # main window bg
$bgPanel     = [Drawing.Color]::FromArgb(22,  22,  27)   # info panel / titlebar
$bgConsole   = [Drawing.Color]::FromArgb(15,  15,  18)   # console area
$bgSubForm   = [Drawing.Color]::FromArgb(30,  30,  36)   # sub-window bg
$bgInput     = [Drawing.Color]::FromArgb(22,  22,  27)   # textbox bg
$border      = [Drawing.Color]::FromArgb(42,  42,  53)   # panel border
$txtPrimary  = [Drawing.Color]::FromArgb(200, 200, 212)  # main text
$txtMuted    = [Drawing.Color]::FromArgb(80,  80,  100)  # labels/dividers
$txtConsole  = [Drawing.Color]::FromArgb(110, 188, 110)  # console green
$txtLink     = [Drawing.Color]::FromArgb(126, 184, 212)  # clickable labels (blue-ish)
$txtLinkHov  = [Drawing.Color]::FromArgb(180, 220, 240)  # hover

# Button bg / fg pairs  [bg, fg]
$btnRun  = @([Drawing.Color]::FromArgb(37,37,53),  [Drawing.Color]::FromArgb(155,143,212))
$btnRed  = @([Drawing.Color]::FromArgb(42,30,30),  [Drawing.Color]::FromArgb(200,112,112))
$btnAmb  = @([Drawing.Color]::FromArgb(42,35,24),  [Drawing.Color]::FromArgb(200,148,58))
$btnTeal = @([Drawing.Color]::FromArgb(30,42,42),  [Drawing.Color]::FromArgb(112,184,168))
$btnBlue = @([Drawing.Color]::FromArgb(30,37,48),  [Drawing.Color]::FromArgb(112,152,200))
$btnDim  = @([Drawing.Color]::FromArgb(22,22,27),  [Drawing.Color]::FromArgb(80,80,100))

# ============================================================
# HELPERS
# ============================================================
function New-Btn($parent, $text, $x, $y, $w, $h, $pair) {
    $b = New-Object Windows.Forms.Button
    $b.Text = $text; $b.Location = "$x,$y"; $b.Size = "$w,$h"
    $b.FlatStyle = "Flat"; $b.ForeColor = $pair[1]; $b.BackColor = $pair[0]
    $b.Font = New-Object Drawing.Font("Segoe UI", 9, [Drawing.FontStyle]::Bold)
    $b.FlatAppearance.BorderColor = $border; $b.FlatAppearance.BorderSize = 1
    $b.TextAlign = "MiddleLeft"; $b.Padding = New-Object Windows.Forms.Padding(8,0,0,0)
    $parent.Controls.Add($b); return $b
}

function New-Lbl($parent, $text, $x, $y, $w, $h, $color, $size=8, $style="Regular") {
    $l = New-Object Windows.Forms.Label
    $l.Text=$text; $l.Location="$x,$y"; $l.Size="$w,$h"
    $l.ForeColor=$color; $l.BackColor=[Drawing.Color]::Transparent
    $l.Font=New-Object Drawing.Font("Consolas",$size,[Drawing.FontStyle]::$style)
    $parent.Controls.Add($l); return $l
}

function New-SectionLbl($text, $y) {
    $l = New-Object Windows.Forms.Label
    $l.Text=$text; $l.Location="12,$y"; $l.Size="430,14"
    $l.ForeColor=$txtMuted; $l.BackColor=[Drawing.Color]::Transparent
    $l.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold)
    $Form.Controls.Add($l)
}

