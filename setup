    $b4.Enabled = $false; $b4.Text = "Working..."
    Show-AppPicker {
        param($selected, $doChrome, $doVLC)
        Run-Installs $selected $doChrome $doVLC
        $b4.Text = "4. INSTALL APPS"; $b4.Enabled = $true
    }
})

# ============================================================
# RUN ALL — shows app picker first, then runs everything
# ============================================================
$bAll.Add_Click({
    $confirm = [Windows.Forms.MessageBox]::Show(
        "This will run ALL tasks:`n`n  • Remove MS Bloat`n  • Privacy & Telemetry`n  • Install selected apps`n`nYou'll choose apps on the next screen.",
        "Run All - Confirm", "YesNo"
    )
    if ($confirm -ne "Yes") { return }

    [System.Media.SystemSounds]::Asterisk.Play()

    # Show app picker — work only starts after it closes
    Show-AppPicker {
        param($selected, $doChrome, $doVLC)

        foreach ($btn in @($bAll,$b1,$b2,$b3,$b4)) { $btn.Enabled = $false }
        $bAll.Text = "⚡ RUNNING ALL..."

        Write-ToUI "=== RUN ALL STARTED ===" "Yellow"
        Run-Debloat
        Run-Privacy
        Run-Installs $selected $doChrome $doVLC

        Write-ToUI "=== RUN ALL COMPLETE! PLEASE RESTART ===" "Yellow"
        [System.Media.SystemSounds]::Exclamation.Play()
        [Windows.Forms.MessageBox]::Show("All tasks complete!`n`nA restart is recommended.", "Done!")
        Refresh-SystemInfo

        $bAll.Text = "⚡ RUN ALL (Bloat + Privacy + Apps)"
        foreach ($btn in @($bAll,$b1,$b2,$b3,$b4)) { $btn.Enabled = $true }
    }
})

