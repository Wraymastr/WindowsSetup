$bAll = New-Object Windows.Forms.Button
$bAll.Text = "⚡ RUN ALL (Bloat + Privacy + Apps)"
$bAll.Location = "10,130"
$bAll.Size = "415,42"
$bAll.FlatStyle = "Flat"
$bAll.ForeColor = "White"
$bAll.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#6f42c1")
$bAll.Font = New-Object Drawing.Font("Segoe UI", 10, [Drawing.FontStyle]::Bold)
$Form.Controls.Add($bAll)

$b1 = New-ActionButton "1. REMOVE MS BLOAT"    182 "#d9534f"
$b2 = New-ActionButton "2. HP CLEANUP"          234 "#c9784e"
$b3 = New-ActionButton "3. PRIVACY & TELEMETRY" 286 "#5bc0de"
$b4 = New-ActionButton "4. INSTALL APPS"        338 "#5cb85c"

# ============================================================
# BUTTON 1 - DEBLOAT
# ============================================================
$b1.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b1.Enabled = $false; $b1.Text = "Working..."
    Run-Debloat
    $b1.Text = "1. REMOVE MS BLOAT"; $b1.Enabled = $true
})

# ============================================================
# BUTTON 2 - HP CLEANUP
# ============================================================
$b2.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b2.Enabled = $false; $b2.Text = "Working..."
    Write-ToUI "Starting HP bloat removal..." "Yellow"
    $hpApps = @("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart")
    foreach ($app in $hpApps) {
        Write-ToUI "  Uninstalling $app..."
        winget uninstall --id $app -e --accept-source-agreements -h --force 2>&1 | Out-Null
    }
    $wolf = Get-CimInstance -ClassName Win32_Product -ErrorAction SilentlyContinue |
        Where-Object { $_.Name -like "*HP Wolf*" -or $_.Name -like "*HP Sure Sense*" }
    foreach ($item in $wolf) {
        Write-ToUI "  Force removing: $($item.Name)" "Orange"
        Invoke-CimMethod -InputObject $item -MethodName "Uninstall" | Out-Null
    }
    Write-ToUI "HP cleanup complete!" "Lime"
    $b2.Text = "2. HP CLEANUP"; $b2.Enabled = $true
})

# ============================================================
# BUTTON 3 - PRIVACY
# ============================================================
$b3.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b3.Enabled = $false; $b3.Text = "Working..."
    Run-Privacy
    $b3.Text = "3. PRIVACY & TELEMETRY"; $b3.Enabled = $true
})

