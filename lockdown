#Requires -Version 5.1
<#
.SYNOPSIS
    Exam Lockdown Tool — A toggleable internet restriction utility for Windows education devices.

.DESCRIPTION
    This script provides a Windows Forms GUI to activate or deactivate an internet lockdown.
    When locked:
      - All HTTP/HTTPS traffic is routed through a black-hole proxy (127.0.0.1:9999)
      - One or more whitelisted domains (and their subdomains) bypass the proxy
      - Users are prevented from changing proxy settings manually
      - A Dead Man's Switch scheduled task auto-restores after N hours
    When unlocked:
      - All original proxy settings are restored from a backup
      - The scheduled task is removed
      - The flag and backup file are deleted

.NOTES
    Must be run as Administrator.
    Tested on Windows 10/11.

    CONFIGURATION — Edit the variables in the "CONFIG" region below.
#>

# ============================================================
# REGION: CONFIGURATION
# Edit these values before deploying.
# ============================================================
$CONFIG = @{
    # Domains to whitelist (and all their subdomains). Comma-separated.
    # Example: "school.edu, exam.org" also covers *.school.edu and *.exam.org
    WhitelistDomain     = "INSERT_DOMAIN_HERE"

    # Black-hole proxy address. Nothing should be listening here.
    BlackHoleProxy      = "127.0.0.1:9999"

    # Hours before the Dead Man's Switch auto-restores the system.
    DeadManHours        = 4

    # Where to store the flag and backup files.
    DataDir             = "$env:ProgramData\ExamLockdown"

    # Registry flag key path (HKLM — requires admin).
    FlagRegPath         = "HKLM:\SOFTWARE\ExamLockdown"
    FlagRegName         = "LockdownActive"

    # Scheduled task name for the Dead Man's Switch.
    TaskName            = "ExamLockdown_DeadMansSwitch"

    # Path to this script (used when registering the scheduled task).
    # Leave as $PSCommandPath to auto-detect.
    ScriptPath          = $PSCommandPath
}

# ============================================================
# REGION: ADMIN PRIVILEGE CHECK
# ============================================================
function Test-Administrator {
    $identity  = [Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = [Security.Principal.WindowsPrincipal]$identity
    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

if (-not (Test-Administrator)) {
    # Re-launch with elevation if not already admin.
    $args = "-ExecutionPolicy Bypass -File `"$PSCommandPath`""
    Start-Process powershell.exe -ArgumentList $args -Verb RunAs
    exit
}

# ============================================================
# REGION: LOGGING UTILITY
# ============================================================
$LogFile = Join-Path $CONFIG.DataDir "lockdown.log"

function Write-Log {
    param([string]$Message, [string]$Level = "INFO")
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $line = "[$timestamp][$Level] $Message"
    try {
        if (-not (Test-Path $CONFIG.DataDir)) { New-Item -Path $CONFIG.DataDir -ItemType Directory -Force | Out-Null }
        Add-Content -Path $LogFile -Value $line -Encoding UTF8
    } catch { <# Swallow log errors silently #> }
    Write-Host $line
}

# ============================================================
# REGION: REGISTRY PROXY HELPERS
# ============================================================
$ProxyRegPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Internet Settings"
$IEPolicyPath = "HKLM:\SOFTWARE\Policies\Microsoft\Internet Explorer\Control Panel"

function Get-ProxySettings {
    <# Returns a hashtable of current HKCU proxy registry values. #>
    $settings = @{}
    $keys = @("ProxyEnable","ProxyServer","ProxyOverride","AutoConfigURL")
    foreach ($key in $keys) {
        try {
            $val = Get-ItemProperty -Path $ProxyRegPath -Name $key -ErrorAction SilentlyContinue
            $settings[$key] = if ($val) { $val.$key } else { $null }
        } catch { $settings[$key] = $null }
    }
    return $settings
}

function Set-ProxySettings {
    param(
        [int]    $Enable,
        [string] $Server,
        [string] $Override
    )
    try {
        Set-ItemProperty -Path $ProxyRegPath -Name "ProxyEnable"   -Value $Enable   -Type DWord   -Force
        Set-ItemProperty -Path $ProxyRegPath -Name "ProxyServer"   -Value $Server   -Type String  -Force
        Set-ItemProperty -Path $ProxyRegPath -Name "ProxyOverride" -Value $Override -Type String  -Force
        # Notify WinINet of the change so browsers pick it up immediately.
        $signature = @"
[DllImport("wininet.dll", SetLastError = true, CharSet = CharSet.Auto)]
public static extern bool InternetSetOption(IntPtr hInternet, int dwOption, IntPtr lpBuffer, int dwBufferLength);
"@
        $wininet = Add-Type -MemberDefinition $signature -Name "WinINet" -Namespace "PInvoke" -PassThru -ErrorAction SilentlyContinue
        if ($wininet) {
            $wininet::InternetSetOption([IntPtr]::Zero, 39, [IntPtr]::Zero, 0) | Out-Null  # INTERNET_OPTION_SETTINGS_CHANGED
            $wininet::InternetSetOption([IntPtr]::Zero, 37, [IntPtr]::Zero, 0) | Out-Null  # INTERNET_OPTION_REFRESH
        }
    } catch {
        Write-Log "Set-ProxySettings error: $_" "ERROR"
    }
}

function Lock-ProxyUI {
    <# Prevents users from editing proxy settings in Windows Settings / IE. #>
    try {
        if (-not (Test-Path $IEPolicyPath)) { New-Item -Path $IEPolicyPath -Force | Out-Null }
        Set-ItemProperty -Path $IEPolicyPath -Name "Proxy" -Value 1 -Type DWord -Force
        Write-Log "Proxy UI locked via Group Policy registry key."
    } catch {
        Write-Log "Lock-ProxyUI error: $_" "WARN"
    }
}

function Unlock-ProxyUI {
    <# Removes the proxy-UI restriction. #>
    try {
        if (Test-Path $IEPolicyPath) {
            Remove-ItemProperty -Path $IEPolicyPath -Name "Proxy" -ErrorAction SilentlyContinue
        }
        Write-Log "Proxy UI restriction removed."
    } catch {
        Write-Log "Unlock-ProxyUI error: $_" "WARN"
    }
}

# ============================================================
# REGION: FLAG MANAGEMENT
# ============================================================
function Test-LockdownFlag {
    try {
        $val = Get-ItemProperty -Path $CONFIG.FlagRegPath -Name $CONFIG.FlagRegName -ErrorAction SilentlyContinue
        return ($null -ne $val -and $val.($CONFIG.FlagRegName) -eq 1)
    } catch { return $false }
}

function Set-LockdownFlag {
    try {
        if (-not (Test-Path $CONFIG.FlagRegPath)) { New-Item -Path $CONFIG.FlagRegPath -Force | Out-Null }
        Set-ItemProperty -Path $CONFIG.FlagRegPath -Name $CONFIG.FlagRegName -Value 1 -Type DWord -Force
        Write-Log "Lockdown flag set."
    } catch { Write-Log "Set-LockdownFlag error: $_" "ERROR" }
}

function Remove-LockdownFlag {
    try {
        if (Test-Path $CONFIG.FlagRegPath) {
            Remove-ItemProperty -Path $CONFIG.FlagRegPath -Name $CONFIG.FlagRegName -ErrorAction SilentlyContinue
        }
        Write-Log "Lockdown flag removed."
    } catch { Write-Log "Remove-LockdownFlag error: $_" "WARN" }
}

# ============================================================
# REGION: BACKUP / RESTORE
# ============================================================
$BackupFile = Join-Path $CONFIG.DataDir "proxy_backup.json"

function Save-ProxyBackup {
    try {
        if (-not (Test-Path $CONFIG.DataDir)) { New-Item -Path $CONFIG.DataDir -ItemType Directory -Force | Out-Null }
        $current = Get-ProxySettings
        $current | ConvertTo-Json -Depth 3 | Set-Content -Path $BackupFile -Encoding UTF8 -Force
        Write-Log "Proxy backup saved to $BackupFile."
    } catch {
        Write-Log "Save-ProxyBackup error: $_" "ERROR"
        throw
    }
}

function Restore-ProxyBackup {
    try {
        if (-not (Test-Path $BackupFile)) {
            Write-Log "Backup file not found — applying safe defaults." "WARN"
            Set-ProxySettings -Enable 0 -Server "" -Override "<local>"
            return
        }
        $backup = Get-Content -Path $BackupFile -Raw -Encoding UTF8 | ConvertFrom-Json
        $bEnable   = if ($null -ne $backup.ProxyEnable)   { [int][string]$backup.ProxyEnable }       else { 0 }
        $bServer   = if ($null -ne $backup.ProxyServer)   { [string]$backup.ProxyServer }            else { "" }
        $bOverride = if ($null -ne $backup.ProxyOverride) { [string]$backup.ProxyOverride }          else { "<local>" }
        Set-ProxySettings -Enable $bEnable -Server $bServer -Override $bOverride

        # Restore AutoConfigURL separately if it existed.
        if ($backup.AutoConfigURL) {
            Set-ItemProperty -Path $ProxyRegPath -Name "AutoConfigURL" -Value $backup.AutoConfigURL -Type String -Force
        } else {
            Remove-ItemProperty -Path $ProxyRegPath -Name "AutoConfigURL" -ErrorAction SilentlyContinue
        }
        Write-Log "Proxy settings restored from backup."
    } catch {
        Write-Log "Restore-ProxyBackup error: $_" "ERROR"
        # Fall-safe: at minimum disable the proxy.
        try { Set-ItemProperty -Path $ProxyRegPath -Name "ProxyEnable" -Value 0 -Type DWord -Force } catch {}
    }
}

function Remove-BackupFile {
    try {
        if (Test-Path $BackupFile) { Remove-Item -Path $BackupFile -Force }
        Write-Log "Backup file removed."
    } catch { Write-Log "Remove-BackupFile error: $_" "WARN" }
}

# ============================================================
# REGION: DNS FLUSH
# ============================================================
function Invoke-DNSFlush {
    try {
        & ipconfig /flushdns 2>&1 | Out-Null
        Write-Log "DNS cache flushed."
    } catch { Write-Log "DNS flush error: $_" "WARN" }
}

# ============================================================
# REGION: DEAD MAN'S SWITCH (Scheduled Task)
# ============================================================
function Register-DeadMansSwitch {
    param([int]$Hours = $CONFIG.DeadManHours)
    try {
        $triggerTime = (Get-Date).AddHours($Hours)
        $scriptArg   = "-ExecutionPolicy Bypass -WindowStyle Hidden -File `"$($CONFIG.ScriptPath)`" -AutoRestore"

        # Build trigger and action objects.
        $trigger = New-ScheduledTaskTrigger -Once -At $triggerTime
        $action  = New-ScheduledTaskAction -Execute "powershell.exe" -Argument $scriptArg
        $settings = New-ScheduledTaskSettingsSet -ExecutionTimeLimit (New-TimeSpan -Hours 1) -DeleteExpiredTaskAfter (New-TimeSpan -Minutes 5)
        $principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest

        Register-ScheduledTask `
            -TaskName  $CONFIG.TaskName `
            -Trigger   $trigger `
            -Action    $action `
            -Settings  $settings `
            -Principal $principal `
            -Force | Out-Null

        Write-Log "Dead Man's Switch scheduled for $($triggerTime.ToString('HH:mm:ss')) ($Hours hours)."
    } catch {
        Write-Log "Register-DeadMansSwitch error: $_" "ERROR"
    }
}

function Unregister-DeadMansSwitch {
    try {
        $task = Get-ScheduledTask -TaskName $CONFIG.TaskName -ErrorAction SilentlyContinue
        if ($task) {
            Unregister-ScheduledTask -TaskName $CONFIG.TaskName -Confirm:$false
            Write-Log "Dead Man's Switch task removed."
        }
    } catch { Write-Log "Unregister-DeadMansSwitch error: $_" "WARN" }
}

function Get-DeadMansSwitchTime {
    <# Returns a string like "14:35" if the task exists, else $null. #>
    try {
        $task = Get-ScheduledTask -TaskName $CONFIG.TaskName -ErrorAction SilentlyContinue
        if ($task) {
            $info = $task | Get-ScheduledTaskInfo -ErrorAction SilentlyContinue
            if ($info.NextRunTime) { return $info.NextRunTime.ToString("HH:mm") }
        }
    } catch {}
    return $null
}

# ============================================================
# REGION: CORE LOCKDOWN / RESTORE LOGIC
# ============================================================
function Invoke-Lockdown {
    Write-Log "===== LOCKDOWN INITIATED ====="
    try {
        Save-ProxyBackup

        # Build ProxyOverride from comma-separated domain list.
        # Each domain gets both the bare domain and a wildcard subdomain entry.
        $domains  = $CONFIG.WhitelistDomain -split '\s*,\s*' | Where-Object { $_ -ne '' } | ForEach-Object { $_.Trim().ToLower() }
        $entries  = foreach ($d in $domains) { $d; "*.$d" }
        $override = ($entries + '<local>') -join ';'

        Set-ProxySettings -Enable 1 -Server $CONFIG.BlackHoleProxy -Override $override

        Lock-ProxyUI
        Invoke-DNSFlush
        Set-LockdownFlag
        Register-DeadMansSwitch -Hours $CONFIG.DeadManHours

        Write-Log "Lockdown complete. Whitelist: $override"
        return $true
    } catch {
        Write-Log "LOCKDOWN FAILED: $_" "ERROR"
        # Attempt rollback.
        try { Restore-ProxyBackup } catch {}
        try { Unlock-ProxyUI      } catch {}
        try { Remove-LockdownFlag } catch {}
        return $false
    }
}

function Invoke-Restore {
    Write-Log "===== RESTORE INITIATED ====="
    try {
        Restore-ProxyBackup
        Unlock-ProxyUI
        Invoke-DNSFlush
        Unregister-DeadMansSwitch
        Remove-LockdownFlag
        Remove-BackupFile
        Write-Log "Restore complete."
        return $true
    } catch {
        Write-Log "RESTORE FAILED: $_" "ERROR"
        return $false
    }
}

# ============================================================
# REGION: AUTO-RESTORE SWITCH (called by scheduled task)
# ============================================================
if ($args -contains "-AutoRestore") {
    Write-Log "Dead Man's Switch triggered — auto-restoring system."
    Invoke-Restore | Out-Null
    exit
}

