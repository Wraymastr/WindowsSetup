$txtLog.Location    = New-Object System.Drawing.Point($MARGIN, $Y_LOG)
$txtLog.BackColor   = $clrPanel
$txtLog.ForeColor   = $clrTextMuted
$txtLog.Font        = New-Object System.Drawing.Font("Consolas", 8)
$txtLog.ReadOnly    = $true
$txtLog.BorderStyle = "None"
$txtLog.ScrollBars  = "Vertical"
$form.Controls.Add($txtLog)

# ---------------------------------------------------------------
# WRITE-UILOG HELPER
# ---------------------------------------------------------------
function Write-UILog {
    param([string]$Msg, [string]$Level = "INFO")
    $ts    = Get-Date -Format "HH:mm:ss"
    $color = switch ($Level) {
        "ERROR" { $clrRed   }
        "WARN"  { $clrAmber }
        "OK"    { $clrGreen }
        default { $clrTextMuted }
    }
    $txtLog.SelectionStart  = $txtLog.TextLength
    $txtLog.SelectionLength = 0
    $txtLog.SelectionColor  = $clrTextMuted
    $txtLog.AppendText("[$ts] ")
    $txtLog.SelectionColor  = $color
    $txtLog.AppendText("$Msg`n")
    $txtLog.ScrollToCaret()
}

# ---------------------------------------------------------------
# PANEL BORDER PAINTER
# ---------------------------------------------------------------
foreach ($pnl in @($pnlStatus, $pnlCfg)) {
    $pnl.Add_Paint({
        param($s, $e)
        $rect = New-Object System.Drawing.Rectangle(0, 0, ($s.Width - 1), ($s.Height - 1))
        $pen  = New-Object System.Drawing.Pen($clrBorder, 1)
        $e.Graphics.SmoothingMode = [System.Drawing.Drawing2D.SmoothingMode]::AntiAlias
        try {
            $path = [GfxHelper]::RoundedRect($rect, 5)
            $e.Graphics.DrawPath($pen, $path)
            $path.Dispose()
        } catch { $e.Graphics.DrawRectangle($pen, $rect) }
        $pen.Dispose()
    })
}

# ---------------------------------------------------------------
# CONFIG DIALOG FUNCTION
# ---------------------------------------------------------------
function Show-ConfigDialog {
    $dlg = New-Object System.Windows.Forms.Form
    $dlg.Text            = "Edit Configuration"
    $dlg.ClientSize      = New-Object System.Drawing.Size(460, 310)
    $dlg.StartPosition   = "CenterParent"
    $dlg.FormBorderStyle = "FixedDialog"
    $dlg.MaximizeBox     = $false
    $dlg.MinimizeBox     = $false
    $dlg.BackColor       = $clrBg
    $dlg.ForeColor       = $clrTextPrimary
    $dlg.Font            = New-Object System.Drawing.Font("Segoe UI", 9)
    $dlg.Icon            = [System.Drawing.SystemIcons]::Shield

    function Add-DlgRow {
        param([string]$Cap, [string]$Val, [string]$Hint, [int]$Y)
        $lbl = New-Object System.Windows.Forms.Label
        $lbl.Text      = $Cap
        $lbl.Font      = New-Object System.Drawing.Font("Segoe UI", 8, [System.Drawing.FontStyle]::Bold)
        $lbl.ForeColor = $clrTextMuted
        $lbl.Size      = New-Object System.Drawing.Size(420, 16)
        $lbl.Location  = New-Object System.Drawing.Point(20, $Y)
        $dlg.Controls.Add($lbl)

        $tb = New-Object System.Windows.Forms.TextBox
        $tb.Text      = $Val
        $tb.Font      = New-Object System.Drawing.Font("Consolas", 10)
        $tb.BackColor = [System.Drawing.Color]::FromArgb(32, 36, 46)
        $tb.ForeColor = $clrTextPrimary
        $tb.BorderStyle = "FixedSingle"
        $tb.Size      = New-Object System.Drawing.Size(420, 24)
        $tb.Location  = New-Object System.Drawing.Point(20, ($Y + 18))
        $dlg.Controls.Add($tb)

        $hint = New-Object System.Windows.Forms.Label
        $hint.Text      = $Hint
        $hint.Font      = New-Object System.Drawing.Font("Segoe UI", 7)
        $hint.ForeColor = $clrTextMuted
        $hint.Size      = New-Object System.Drawing.Size(420, 14)
        $hint.Location  = New-Object System.Drawing.Point(20, ($Y + 44))
        $dlg.Controls.Add($hint)

        return $tb
    }

    $tbDomain = Add-DlgRow `
        "Whitelist Domains  (comma-separated)" `
        $CONFIG.WhitelistDomain `
        "e.g.  school.edu, exam.org   — subdomains are whitelisted automatically for each" `
        16

    $tbProxy = Add-DlgRow `
        "Black-hole Proxy  (nothing should be listening here)" `
        $CONFIG.BlackHoleProxy `
        "Default: 127.0.0.1:9999  — change only if that port is in use" `
        90

    $tbHours = Add-DlgRow `
        "Dead Man's Switch — auto-restore after N hours" `
        ([string]$CONFIG.DeadManHours) `
        "Enter a whole number between 1 and 24" `
        164

    # Warning banner shown when system is locked
    $lockWarn = New-Object System.Windows.Forms.Label
    $lockWarn.Text      = "  Changes will take effect on the next lockdown cycle."
    $lockWarn.Font      = New-Object System.Drawing.Font("Segoe UI", 8)
    $lockWarn.ForeColor = $clrAmber
    $lockWarn.BackColor = [System.Drawing.Color]::FromArgb(50, 40, 10)
    $lockWarn.Size      = New-Object System.Drawing.Size(420, 22)
    $lockWarn.Location  = New-Object System.Drawing.Point(20, 238)
    $lockWarn.Visible   = $script:IsLocked
    $dlg.Controls.Add($lockWarn)

    # Save button
    $btnSave = New-Object System.Windows.Forms.Button
    $btnSave.Text      = "SAVE"
    $btnSave.Font      = New-Object System.Drawing.Font("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)
    $btnSave.Size      = New-Object System.Drawing.Size(200, 36)
    $btnSave.Location  = New-Object System.Drawing.Point(20, 264)
    $btnSave.FlatStyle = "Flat"
    $btnSave.FlatAppearance.BorderSize = 0
    $btnSave.BackColor = $clrAccentCfg
    $btnSave.ForeColor = [System.Drawing.Color]::White
    $btnSave.Cursor    = [System.Windows.Forms.Cursors]::Hand
    $dlg.Controls.Add($btnSave)

    # Cancel button
    $btnCancel = New-Object System.Windows.Forms.Button
    $btnCancel.Text      = "CANCEL"
    $btnCancel.Font      = New-Object System.Drawing.Font("Segoe UI", 10)
    $btnCancel.Size      = New-Object System.Drawing.Size(200, 36)
    $btnCancel.Location  = New-Object System.Drawing.Point(240, 264)
    $btnCancel.FlatStyle = "Flat"
    $btnCancel.FlatAppearance.BorderColor = $clrBorder
    $btnCancel.FlatAppearance.BorderSize  = 1
    $btnCancel.BackColor = $clrPanel
    $btnCancel.ForeColor = $clrTextMuted
    $btnCancel.Cursor    = [System.Windows.Forms.Cursors]::Hand
    $dlg.Controls.Add($btnCancel)

    $btnCancel.Add_Click({ $dlg.Close() })

    $btnSave.Add_Click({
        # Validate hours field
        $h = 0
        if (-not [int]::TryParse($tbHours.Text.Trim(), [ref]$h) -or $h -lt 1 -or $h -gt 24) {
            [System.Windows.Forms.MessageBox]::Show(
                "Dead Man's Switch hours must be a whole number from 1 to 24.",
                "Validation Error", "OK", "Warning") | Out-Null
            return
        }
        # Validate domain list — at least one non-empty entry required
        $domainList = $tbDomain.Text -split '\s*,\s*' | Where-Object { $_ -ne '' }
        if ($domainList.Count -eq 0) {
            [System.Windows.Forms.MessageBox]::Show(
                "At least one whitelist domain is required.",
                "Validation Error", "OK", "Warning") | Out-Null
            return
        }

        # Apply to CONFIG
        $CONFIG.WhitelistDomain = ($domainList -join ', ').ToLower()
        $CONFIG.BlackHoleProxy  = $tbProxy.Text.Trim()
        $CONFIG.DeadManHours    = $h

        # Refresh display labels on main form
        $valDomain.Text = $CONFIG.WhitelistDomain
        $valProxy.Text  = $CONFIG.BlackHoleProxy
        $valDMH.Text    = "$($CONFIG.DeadManHours)h via Dead Man's Switch"

        $domainCount = $domainList.Count
        Write-UILog "Configuration updated: $domainCount domain(s) whitelisted, proxy=$($CONFIG.BlackHoleProxy), hours=$($CONFIG.DeadManHours)" "OK"
        $dlg.Close()
    })

    $dlg.ShowDialog($form) | Out-Null
}

# ---------------------------------------------------------------
# UPDATE-UI  — refreshes all state-driven controls
# ---------------------------------------------------------------
$script:IsLocked = $false

function Update-UI {
    $script:IsLocked = Test-LockdownFlag

    if ($script:IsLocked) {
        $lblStatusValue.Text      = "LOCKED"
        $lblStatusValue.ForeColor = $clrRed
        $lblStatusSub.Text        = "Internet restricted — only whitelisted domain passes."
        $script:dotColor          = $clrRed
        $btnAction.Text           = "RESTORE SYSTEM"
        $btnAction.BackColor      = $clrAccentRest
        $pnlDMS.Visible           = $true
        $btnConfig.Enabled        = $true   # still allow config edits (takes effect next cycle)

        $dmsTime = Get-DeadMansSwitchTime
        if ($dmsTime) {
            $lblDMSText.Text = "  Dead Man's Switch active — auto-restore scheduled at $dmsTime"
        }
    } else {
        $lblStatusValue.Text      = "NORMAL"
        $lblStatusValue.ForeColor = $clrGreen
        $lblStatusSub.Text        = "All internet traffic is unrestricted."
        $script:dotColor          = $clrGreen
        $btnAction.Text           = "ACTIVATE LOCKDOWN"
        $btnAction.BackColor      = $clrAccentLock
        $pnlDMS.Visible           = $false
        $btnConfig.Enabled        = $true
    }

    $picDot.Invalidate()
    $form.Refresh()
}

# ---------------------------------------------------------------
# BUTTON EVENT HANDLERS
# ---------------------------------------------------------------
$btnConfig.Add_Click({ Show-ConfigDialog })

$btnAction.Add_Click({
    $btnAction.Enabled  = $false
    $btnConfig.Enabled  = $false
    $btnAction.Text     = "WORKING..."

    if (-not $script:IsLocked) {
        Write-UILog "Initiating lockdown..." "INFO"
        $ok = Invoke-Lockdown
        if ($ok) {
            Write-UILog "Lockdown ACTIVE — proxy: $($CONFIG.BlackHoleProxy)" "OK"
            Write-UILog "Whitelist: $($CONFIG.WhitelistDomain) + subdomains" "OK"
            Write-UILog "Dead Man's Switch fires in $($CONFIG.DeadManHours)h" "OK"
        } else {
            Write-UILog "Lockdown FAILED — see log file for details." "ERROR"
            [System.Windows.Forms.MessageBox]::Show(
                "Lockdown failed. Check the activity log.",
                "Error", "OK", "Error") | Out-Null
        }
    } else {
        $confirm = [System.Windows.Forms.MessageBox]::Show(
            "Restore system to normal operation?",
            "Confirm Restore", "YesNo", "Question")
        if ($confirm -eq "Yes") {
            Write-UILog "Initiating restore..." "INFO"
            $ok = Invoke-Restore
            if ($ok) {
                Write-UILog "System RESTORED — all restrictions removed." "OK"
            } else {
                Write-UILog "Restore had errors — check: $LogFile" "ERROR"
            }
        } else {
            Write-UILog "Restore cancelled by user." "WARN"
        }
    }

    $btnAction.Enabled = $true
    $btnConfig.Enabled = $true
    Update-UI
})

# ---------------------------------------------------------------
# STARTUP
# ---------------------------------------------------------------
Update-UI

Write-UILog "Exam Lockdown Tool v2.1 started."
Write-UILog "Host: $($env:COMPUTERNAME)  •  User: $($env:USERNAME)"

if ($CONFIG.WhitelistDomain -eq "INSERT_DOMAIN_HERE" -or [string]::IsNullOrWhiteSpace($CONFIG.WhitelistDomain)) {
    Write-UILog "No domain configured — click EDIT CONFIGURATION to set one." "WARN"
}

if ($script:IsLocked) {
    Write-UILog "Existing lockdown detected — system is currently LOCKED." "WARN"
} else {
    Write-UILog "System is NORMAL. Ready to activate lockdown."
}

[System.Windows.Forms.Application]::Run($form)
