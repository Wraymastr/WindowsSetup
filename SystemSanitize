Section "STEP 1 — MICROSOFT BLOAT REMOVAL"

$bloatApps = @(
    "*MicrosoftTeams*","*MSTeams*","*Cortana*",
    "*YourPhone*","*MicrosoftToDo*","*MicrosoftOfficeHub*",
    "Microsoft.Messaging","Microsoft.OneConnect",
    "*Clipchamp*","*ZuneMusic*","*ZuneVideo*",
    "*Xbox","*XboxApp*","*XboxGameOverlay*","*XboxGamingOverlay*",
    "*XboxIdentityProvider*","*XboxSpeechToTextOverlay*",
    "*BingSearch*","*BingWeather*","*BingNews*","*BingFinance*",
    "*BingSports*","*BingTranslator*","Microsoft.BingHealthAndFitness",
    "*MicrosoftNews*","*WindowsFeedbackHub*",
    "*GetHelp*","*FeedbackHub*","*WindowsMaps*",
    "*MicrosoftSolitaireCollection*","*MixedReality*",
    "*3DViewer*","*Microsoft3DViewer*","*Print3D*",
    "*Microsoft.549981C3F5F10*",

    # ---COPILOT ---
    "*Microsoft.Copilot*",             # The main Copilot app
    "*Microsoft.Windows.Copilot*",     # System-integrated version
    "*EdgeEdgeWatson*",                # Edge's AI feedback/integration

    # --- PERSISTENT SYSTEM BLOAT ---
    "*People",                        # Microsoft.People
    "*GetStarted*",                    # "Tips" app
    "*SkypeApp*",
    "*WindowsAlarms*",                 # Clock/Timer
    "*WindowsSoundRecorder*",
    "*Microsoft.Wallet*",
    "*OutlookForWindows*",             # The "New Outlook" forced preview
    "*PowerAutomateDesktop*",

    # --- THIRD-PARTY SPONSORED (OEM) ---
    "*Disney*","*Spotify*","*Netflix*",
    "*CandyCrush*","*HiddenCity*",
    "*TikTok*","*Instagram*"
)

foreach($app in $bloatApps){
    Log "Checking: $app" "Gray"
    Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue | ForEach-Object {
        Log "  Removing: $($_.Name)" "Yellow"
        Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue
    }
    Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue |
        Where-Object {$_.DisplayName -like $app} | ForEach-Object {
            Log "  Removing provisioned: $($_.DisplayName)" "Yellow"
            Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue
        }
}

# Winget removal for Bing and News apps that resist AppX removal
Log "Attempting Winget removal of Bing/News apps..." "Cyan"
$wingetBloat = @(
    "Microsoft.BingNews",
    "Microsoft.BingWeather",
    "Microsoft.BingSearch",
    "Microsoft.BingFinance",
    "Microsoft.BingSports",
    "Microsoft.Todos",
    "Microsoft.XboxApp",
    "Microsoft.GamingApp"
)
foreach($app in $wingetBloat){
    Log "  Winget uninstall: $app" "Gray"
    winget uninstall --id $app -e --accept-source-agreements -h --force 2>&1 | Out-Null
}

Log "Microsoft has been successfully debloated.." "Green"

# ============================================================
# SECTION 2 — VENDOR PURGE
# ============================================================
Section "STEP 2 — VENDOR PURGE"

$manufacturer = (Get-CimInstance Win32_ComputerSystem).Manufacturer
Log "Detected manufacturer: $manufacturer" "Cyan"

$vendor = "Unknown"
if($manufacturer -match "HP|Hewlett")  { $vendor = "HP" }
elseif($manufacturer -match "Dell")    { $vendor = "Dell" }
elseif($manufacturer -match "Lenovo")  { $vendor = "Lenovo" }
elseif($manufacturer -match "Acer")    { $vendor = "Acer" }
elseif($manufacturer -match "ASUS")    { $vendor = "ASUS" }
elseif($manufacturer -match "MSI")     { $vendor = "MSI" }
elseif($manufacturer -match "Toshiba") { $vendor = "Toshiba" }
elseif($manufacturer -match "Samsung") { $vendor = "Samsung" }
elseif($manufacturer -match "Microsoft"){ $vendor = "Microsoft" }

if($vendor -eq "Unknown"){
    Log "Unknown vendor — skipping vendor purge." "Yellow"
} else {
    Log "Running $vendor bloatware removal..." "Cyan"

    $vendorBloat = @{
        "HP"       = @("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart","HP.HPAudioCenter","HP.HPSystemEventUtility","HP.HPEnhance","HP.HPPCHardwareDiagnosticsWindows","HP.HPNotifications","AD2F1837.HPPrinterControl")
        "Dell"     = @("Dell.DellSupportAssistforPCs","Dell.DellOptimizer","Dell.DellDigitalDelivery","Dell.DellUpdate","Dell.DellCommandUpdate","Dell.DellPowerManager","Dell.DellCinemaGuide","Dell.DellMobileConnect","Dell.DellCinema","DellInc.DellSupportAssistforPCs")
        "Lenovo"   = @("E046963F.LenovoCompanion","E046963F.LenovoSettings","E0469640.LenovoUtility","LenovoCorporation.LenovoSettings","LenovoCorporation.LenovoID","LenovoCorporation.LenovoCompanion")
        "Acer"     = @("AcerIncorporated.AcerRegistration","AcerIncorporated.QuickAccess","AcerIncorporated.AcerCollection","AcerIncorporated.AcerCareCenterS","AcerIncorporated.AcerJumpStart")
        "ASUS"     = @("ASUSTeKCOMPUTERINC.MyASUS","ASUSTeKCOMPUTERINC.ASUSProductRegistrationProgram","ASUSTeKCOMPUTERINC.ASUSWelcome","ASUSTeKCOMPUTERINC.ASUSLiveUpdate")
        "MSI"      = @("MSI.CenterFacade","MSI.DragonCenter","MSI.MSICenter","MSI.MSICenterSDK")
        "Toshiba"  = @("ToshibaCorporation.ToshibaServiceStation","ToshibaCorporation.SettingsforYourTOSHIBA")
        "Samsung"  = @("HONHAIPREC.Samsung_Update","HONHAIPREC.SamsungUpdate")
        "Microsoft"= @("Microsoft.SurfaceHub","Microsoft.PPIProjection")
    }

    $vendorWinget = @{
        "HP"      = @("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart")
        "Dell"    = @("Dell.CommandUpdate","Dell.DellOptimizer","Dell.DellSupportAssist","Dell.DellDigitalDelivery","Dell.DellPowerManager")
        "Lenovo"  = @("Lenovo.SystemUpdate","Lenovo.VantageService","Lenovo.SmartAppearance")
        "Acer"    = @("Acer.AcerCollection","Acer.QuickAccess")
        "ASUS"=@(); "MSI"=@(); "Toshiba"=@(); "Samsung"=@(); "Microsoft"=@()
    }

    # AppX removal
    foreach($app in $vendorBloat[$vendor]){
        Log "Checking AppX: $app" "Gray"
        Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue | ForEach-Object {
            Log "  Removing: $($_.Name)" "Yellow"
            Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue
        }
        Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue |
            Where-Object {$_.DisplayName -like $app} | ForEach-Object {
                Log "  Removing provisioned: $($_.DisplayName)" "Yellow"
                Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue
            }
    }

    # Winget uninstall
    if($vendorWinget[$vendor].Count -gt 0){
        foreach($app in $vendorWinget[$vendor]){
            Log "Uninstalling via Winget: $app" "Gray"
            winget uninstall --id $app -e --accept-source-agreements -h --force 2>&1 | Out-Null
        }
    }

    # WMI nuclear options for stubborn installs
    $wmiQueries = @{
        "HP"     = @("*HP Wolf*","*HP Sure Sense*")
        "Lenovo" = @("*Lenovo Vantage*")
        "Dell"   = @("*Dell Support*")
    }
    if($wmiQueries.ContainsKey($vendor)){
        foreach($pattern in $wmiQueries[$vendor]){
            Get-CimInstance Win32_Product -ErrorAction SilentlyContinue |
                Where-Object {$_.Name -like $pattern} | ForEach-Object {
                    Log "  Force removing: $($_.Name)" "Yellow"
                    Invoke-CimMethod -InputObject $_ -MethodName "Uninstall" | Out-Null
                }
        }
    }

    Log "$vendor purge ... complete." "Green"
}

