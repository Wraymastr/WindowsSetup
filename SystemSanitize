Section "STEP 3 — ESSENTIAL TWEAKS"

# Telemetry
Log "Disabling telemetry..." "Cyan"
Set-ItemProperty "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection" "AllowTelemetry" 0 -ErrorAction SilentlyContinue
Set-Service -Name "DiagTrack" -StartupType Disabled -ErrorAction SilentlyContinue
Log "  Telemetry is dead. Microsoft can mind its own business now.." "Green"

$ads = "HKCU:\Software\Microsoft\Windows\CurrentVersion\ContentDeliveryManager"
"SubscribedContent-310093Enabled","SubscribedContent-353696Enabled",
"RotatingLockScreenOverlayEnabled","SubscribedContent-338387Enabled" | ForEach-Object {
    Set-ItemProperty -Path $ads -Name $_ -Value 0 -ErrorAction SilentlyContinue
}
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\AdvertisingInfo" "Enabled" 0 -ErrorAction SilentlyContinue
Log "  Ads and tailored experiences disabled." "Green"

# Bing search
Log "Disabling Bing in Start Menu..." "Cyan"
$searchPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search"
if(-not(Test-Path $searchPath)){New-Item -Path $searchPath -Force|Out-Null}
Set-ItemProperty $searchPath "BingSearchEnabled"        0 -ErrorAction SilentlyContinue
Set-ItemProperty $searchPath "CortanaConsent"           0 -ErrorAction SilentlyContinue
Set-ItemProperty $searchPath "AllowSearchToUseLocation" 0 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\SearchSettings" "IsDynamicSearchBoxPresent" 0 -ErrorAction SilentlyContinue
$searchPol = "HKCU:\Software\Policies\Microsoft\Windows\Explorer"
if(-not(Test-Path $searchPol)){New-Item -Path $searchPol -Force|Out-Null}
Set-ItemProperty $searchPol "DisableSearchBoxSuggestions" 1 -ErrorAction SilentlyContinue
$machinePol = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search"
if(-not(Test-Path $machinePol)){New-Item -Path $machinePol -Force|Out-Null}
Set-ItemProperty $machinePol "DisableWebSearch"      1 -ErrorAction SilentlyContinue
Set-ItemProperty $machinePol "ConnectedSearchUseWeb" 0 -ErrorAction SilentlyContinue
Log "  Search is local again. No more BING in your menus." "Green"

# Taskbar
Log "Cleaning taskbar..." "Cyan"
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Feeds"             "ShellFeedsTaskbarViewMode" 2 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "PeopleBand"                0 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" "HideSCAMeetNow"            1 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "ShowTaskViewButton"         0 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "TaskbarDa"                 0 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "ShowCopilotButton"         0 -ErrorAction SilentlyContinue
Log "  Taskbar cleaned." "Green"

# Move Taskbar Alignment to the Left (Win10 style)
Log "Moving Taskbar alignment to the left..." "Cyan"
Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "TaskbarAl" -Value 0 -ErrorAction SilentlyContinue
Log "  Taskbar has moved back to the left, and is finally free" "Green"

# Widgets
Log "Disabling Widgets..." "Cyan"
$wp = "HKLM:\SOFTWARE\Policies\Microsoft\Dsh"
if(-not(Test-Path $wp)){New-Item -Path $wp -Force|Out-Null}
Set-ItemProperty $wp "AllowNewsAndInterests" 0 -ErrorAction SilentlyContinue
Log "  Taskbar ads are finished." "Green"

# Edge
Log "Disabling Edge startup boost..." "Cyan"
Set-ItemProperty "HKLM:\SOFTWARE\Policies\Microsoft\Edge" "StartupBoostEnabled"   0 -ErrorAction SilentlyContinue
Set-ItemProperty "HKLM:\SOFTWARE\Policies\Microsoft\Edge" "BackgroundModeEnabled"  0 -ErrorAction SilentlyContinue
Log "  Edge startup boost disabled." "Green"
# Stop Edge from sharing data with Windows for "Personalization"
$edgePers = "HKLM:\SOFTWARE\Policies\Microsoft\Edge"
if(!(Test-Path $edgePers)) { New-Item $edgePers -Force }
Set-ItemProperty -Path $edgePers -Name "HubsSidebarEnabled" -Value 0
Log "  Edge has been gimped." "Green"

# Update hours
Log "Setting update active hours 8am-5pm..." "Cyan"
Set-ItemProperty "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings" "ActiveHoursStart" 8  -ErrorAction SilentlyContinue
Set-ItemProperty "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings" "ActiveHoursEnd"   17 -ErrorAction SilentlyContinue
Log "  Active hours set." "Green"

# Disable Windows Spotlight & Tips
Log "Silencing Microsoft's 'helpful' suggestions..." "Cyan"
$capPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\ContentDeliveryManager"
Set-ItemProperty -Path $capPath -Name "SoftLandingEnabled" -Value 0 -ErrorAction SilentlyContinue
Set-ItemProperty -Path $capPath -Name "SubscribedContent-338389Enabled" -Value 0 -ErrorAction SilentlyContinue
Log "  Windows unsolicited advice has been terminated." "Green"

# Explorer tweaks
Log "Restoring sanity to File Explorer......" "Cyan"
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "HideFileExt"    0 -ErrorAction SilentlyContinue
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "AutoCheckSelect" 0 -ErrorAction SilentlyContinue
Log "  File extensions are visible. No more guessing games." "Green"

# Timezone
Log "Setting timezone to NZ Standard Time..." "Cyan"
try {
    Set-TimeZone -Id "New Zealand Standard Time" -ErrorAction Stop
    Log "  Timezone set." "Green"
} catch {
    Log "  Timezone change failed — set manually." "Yellow"
}

# Right-click menu
Log "Reviving Windows 10 right-click menu..." "Cyan"
$rc = "HKCU:\Software\Classes\CLSID\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}\InprocServer32"
if(-not(Test-Path $rc)){New-Item -Path $rc -Force|Out-Null}
Set-ItemProperty $rc "(default)" "" -ErrorAction SilentlyContinue
Log "  Right-click menu restored. Welcome back old friend" "Green"

# Run key cleanup
Log "Clearing startup Run keys..." "Cyan"
@("HKCU:\Software\Microsoft\Windows\CurrentVersion\Run",
  "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run") | ForEach-Object {
    $p = $_
    (Get-ItemProperty -Path $p -ErrorAction SilentlyContinue).PSObject.Properties |
        Where-Object {$_.Name -notlike "PS*"} | ForEach-Object {
            Log "  Removing run key: $($_.Name)" "Yellow"
            Remove-ItemProperty -Path $p -Name $_.Name -ErrorAction SilentlyContinue
        }
}
Log "  Run keys cleared." "Green"

# Autostart policies (no Task Scheduler calls — instant)
Log "Intercepting Microsoft autostart protocols..." "Cyan"

# Edge
Remove-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -Name "Microsoft Edge" -ErrorAction SilentlyContinue
Log "  Edge autostart blocked." "Yellow"

# OneDrive
$odPolicy = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\OneDrive"
if(-not(Test-Path $odPolicy)){New-Item -Path $odPolicy -Force|Out-Null}
Set-ItemProperty $odPolicy "DisableFileSyncNGSC" 1 -ErrorAction SilentlyContinue
Remove-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -Name "OneDrive" -ErrorAction SilentlyContinue

# Redirecting User Folders away from OneDrive
Log "Reclaiming local storage from OneDrive's clutches..." "Cyan"
$folders = @("Desktop", "Personal", "My Pictures", "My Video", "My Music")
$shellFolders = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\User Shell Folders"
foreach ($f in $folders) {
    $current = (Get-ItemProperty $shellFolders).$f
    if ($current -match "OneDrive") {
        $newPath = $current -replace "OneDrive\\", ""
        Set-ItemProperty -Path $shellFolders -Name $f -Value $newPath -ErrorAction SilentlyContinue
    }
}
# Stop OneDrive from being the default Save location for Office
$office = "HKCU:\Software\Microsoft\Office\Common\General"
if(!(Test-Path $office)) { New-Item $office -Force | Out-Null }
Set-ItemProperty -Path $office -Name "PreferCloudSaveLocations" -Value 0 -ErrorAction SilentlyContinue

Log "  Default save locations restored to local disk." "Green"
Log "  Onedrive has been castrated" "Green"

# Teams
$teamsPolicy = "HKLM:\SOFTWARE\Policies\Microsoft\MicrosoftTeams"
if(-not(Test-Path $teamsPolicy)){New-Item -Path $teamsPolicy -Force|Out-Null}
Set-ItemProperty $teamsPolicy "DisableAutoStart" 1 -ErrorAction SilentlyContinue
Remove-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -Name "Teams" -ErrorAction SilentlyContinue
Remove-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -Name "com.squirrel.Teams.Teams" -ErrorAction SilentlyContinue
Log "  Teams autostart process has also been killed." "Yellow"

# Copilot
$copU = "HKCU:\Software\Policies\Microsoft\Windows\WindowsCopilot"
$copM = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot"
foreach($p in @($copU,$copM)){
    if(-not(Test-Path $p)){New-Item -Path $p -Force|Out-Null}
    Set-ItemProperty $p "TurnOffWindowsCopilot" 1 -ErrorAction SilentlyContinue
}
Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" "ShowCopilotButton" 0 -ErrorAction SilentlyContinue
Log "  Copilot blocked." "Yellow"

Log "  OneDrive and Teams have been neutralized." "Green"

# Disable Edge Local AI Foundational Models
Log "Disabling Edge Local AI Foundational Models..." "Cyan"
$edgePolicy = "HKLM:\SOFTWARE\Policies\Microsoft\Edge"
if(!(Test-Path $edgePolicy)) { New-Item $edgePolicy -Force | Out-Null }
Set-ItemProperty -Path $edgePolicy -Name "GenAILocalFoundationalModelSettings" -Value 1 -ErrorAction SilentlyContinue
Log "  Local AI models disabled for Edge." "Green"

